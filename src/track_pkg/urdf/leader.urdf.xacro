<?xml version="1.0"?>
<robot name="leader_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">
    <!-- Property definitions -->
    <xacro:property name="base_width" value="0.35"/>
    <xacro:property name="base_length" value="0.45"/>
    <xacro:property name="base_height" value="0.15"/>
    <xacro:property name="wheel_radius" value="0.08"/>
    <xacro:property name="wheel_width" value="0.04"/>
    <xacro:property name="wheel_separation_length" value="0.30"/>
    <xacro:property name="marker_width" value="0.2"/>
    <xacro:property name="marker_height" value="0.2"/>
    <xacro:property name="marker_thickness" value="0.01"/>

    <!-- Base link -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
            <material name="Gazebo/Blue"/>
        </visual>
        <collision>
            <geometry>
                <box size="${base_length} ${base_width} ${base_height}"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="1.0"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <!-- 添加后部标记板 -->
    <link name="marker_board">
        <visual>
            <geometry>
                <box size="${marker_thickness} ${marker_width} ${marker_height}"/>
            </geometry>
            <material name="Gazebo/Yellow"/>
        </visual>
        <collision>
            <geometry>
                <box size="${marker_thickness} ${marker_width} ${marker_height}"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <!-- 标记板关节 -->
    <joint name="marker_board_joint" type="fixed">
        <parent link="base_link"/>
        <child link="marker_board"/>
        <origin xyz="${-base_length/2 - marker_thickness/2} 0 ${base_height/2}" rpy="0 0 0"/>
    </joint>

    <!-- 添加顶部标记图案 -->
    <link name="top_pattern">
        <visual>
            <geometry>
                <box size="${marker_width} ${marker_width} ${marker_thickness}"/>
            </geometry>
            <material name="Gazebo/Yellow"/>
        </visual>
        <inertial>
            <mass value="0.01"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

    <!-- 顶部图案关节 -->
    <joint name="top_pattern_joint" type="fixed">
        <parent link="base_link"/>
        <child link="top_pattern"/>
        <origin xyz="0 0 ${base_height/2 + marker_thickness/2}" rpy="0 0 0"/>
    </joint>

    <!-- Wheel Macro -->
    <xacro:macro name="wheel" params="prefix suffix x_reflect y_reflect">
        <link name="${prefix}_${suffix}_wheel">
            <visual>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
                <material name="Gazebo/Black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
                </geometry>
            </collision>
            <inertial>
                <mass value="0.1"/>
                <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
            </inertial>
        </link>

        <joint name="${prefix}_${suffix}_wheel_joint" type="continuous">
            <parent link="base_link"/>
            <child link="${prefix}_${suffix}_wheel"/>
            <origin xyz="${x_reflect*wheel_separation_length/2} ${y_reflect*(base_width/2 + wheel_width/2)} 0" rpy="${pi/2} 0 0"/>
            <axis xyz="0 0 1"/>
        </joint>

        <gazebo reference="${prefix}_${suffix}_wheel">
            <material>Gazebo/Black</material>
            <mu1>2.0</mu1>
            <mu2>2.0</mu2>
            <kp>1000000.0</kp>
            <kd>100.0</kd>
        </gazebo>
    </xacro:macro>

    <!-- Create wheels -->
    <xacro:wheel prefix="front" suffix="left"  x_reflect="1" y_reflect="1" />
    <xacro:wheel prefix="front" suffix="right" x_reflect="1" y_reflect="-1" />
    <xacro:wheel prefix="rear"  suffix="left"  x_reflect="-1" y_reflect="1" />
    <xacro:wheel prefix="rear"  suffix="right" x_reflect="-1" y_reflect="-1" />

    <!-- Gazebo materials -->
    <gazebo reference="base_link">
        <material>Gazebo/Blue</material>
        <mu1>0.2</mu1>
        <mu2>0.2</mu2>
    </gazebo>

    <!-- 为新添加的部件设置Gazebo材质 -->
    <gazebo reference="marker_board">
        <material>Gazebo/Yellow</material>
    </gazebo>

    <gazebo reference="top_pattern">
        <material>Gazebo/Yellow</material>
    </gazebo>

    <!-- Gazebo plugin -->
    <gazebo>
        <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
            <!-- Left -->
            <leftJoint>front_left_wheel_joint</leftJoint>
            <leftJoint>rear_left_wheel_joint</leftJoint>
            <!-- Right -->
            <rightJoint>front_right_wheel_joint</rightJoint>
            <rightJoint>rear_right_wheel_joint</rightJoint>
            
            <wheelSeparation>${base_width}</wheelSeparation>
            <wheelDiameter>${2*wheel_radius}</wheelDiameter>
            <robotBaseFrame>base_link</robotBaseFrame>
            <commandTopic>leader/cmd_vel</commandTopic>
            <odometryTopic>leader/odom</odometryTopic>
            <odometryFrame>leader/odom</odometryFrame>
            <robotNamespace>/</robotNamespace>
            <publishWheelTF>true</publishWheelTF>
            <publishWheelJointState>true</publishWheelJointState>
            <publishOdomTF>true</publishOdomTF>
            <odometrySource>world</odometrySource>
            <updateRate>100.0</updateRate>
            <wheelAcceleration>20.0</wheelAcceleration>
            <wheelTorque>200.0</wheelTorque>
            <maxVelocity>5.0</maxVelocity>
            <maxAcceleration>10.0</maxAcceleration>
            <leftJointMaxVelocity>200.0</leftJointMaxVelocity>
            <rightJointMaxVelocity>200.0</rightJointMaxVelocity>
            <wheelSlip>0.001</wheelSlip>
            <robotBaseFrame>base_link</robotBaseFrame>
            <rosDebugLevel>Debug</rosDebugLevel>
            <legacyMode>false</legacyMode>
        </plugin>
    </gazebo>
</robot>